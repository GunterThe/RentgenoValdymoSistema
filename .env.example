# Production environment variables (copy to .env and fill values)

# Public domain pointing to your server (A/AAAA DNS record)
DOMAIN=example.com
LETSENCRYPT_EMAIL=admin@example.com

# Database
POSTGRES_PASSWORD=change_me

# JWT settings (MUST be strong random)
JWT_ISSUER=RentgenoValdymoSistema
JWT_AUDIENCE=RentgenoValdymoSistema
JWT_KEY=replace_with_long_random_secret

# Optional
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
