{
  # Optional: set an email for Let's Encrypt account.
  email {$LETSENCRYPT_EMAIL}
}

{$DOMAIN} {
  # Allow larger uploads (adjust if needed)
  request_body {
    max_size 100MB
  }

  # Proxy API to backend service (must run before SPA rewrites)
  handle /api/* {
    reverse_proxy backend:8080
  }

  # Flutter web SPA
  handle {
    root * /usr/share/caddy

    # SPA routing
    try_files {path} /index.html

    file_server
  }
}
